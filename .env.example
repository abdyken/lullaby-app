# Lullaby — example env (safe-by-default template).
#
# Copy to .env and fill in real values. Every EXPO_PUBLIC_* variable is inlined
# into the JS bundle at build time and is PUBLIC — never put a secret in one.
# docs/release-env.md is the per-posture source of truth; the §RE smoke checks
# in scripts/check-local-interactions.ts pin this file to safe beta defaults.
#
# Server-side secrets (ANTHROPIC_API_KEY, REASSURE_MODEL,
# REASSURE_NIGHT_READ_ENABLED, SUPABASE_SERVICE_ROLE_KEY) live in Supabase
# edge-function config — never here, never in any EXPO_PUBLIC_* variable.

# ── Supabase (client) — real project URL + anon (publishable) key only ───────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── Google sign-in — the OAuth *web* client id ────────────────────────────────
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ── Onboarding (dev/QA only; inert in release binaries) ──────────────────────
# true replays the pre-account intro on every launch on a dev build. Keep false:
# a guest completing the replay re-creates the local baby and clears local events.
EXPO_PUBLIC_FORCE_ONBOARDING=false

# ── Pro / RevenueCat — OFF by default (see docs/release-env.md beta rule) ────
# Pro ships OFF unless a build explicitly enables it AND provides real
# RevenueCat public SDK keys. Enabled-with-empty-keys is the "unconfigured"
# degrade state — never ship it on purpose.
EXPO_PUBLIC_PRO_ENABLED=0
EXPO_PUBLIC_PRO_PREVIEW_ENABLED=0
# Dev-build-only entitlement override (ignored by release binaries). Keep 0.
EXPO_PUBLIC_PRO_DEV_ENTITLEMENT=0
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
# Must match the RevenueCat dashboard; code defaults below.
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=pro
EXPO_PUBLIC_REVENUECAT_OFFERING_ID=default

# ── Theme ─────────────────────────────────────────────────────────────────────
# Optional override for the day/night reveal duration (ms); unset = code default.
EXPO_PUBLIC_THEME_REVEAL_DURATION_MS=

# ── Caregiver invite share copy ───────────────────────────────────────────────
# Optional beta install link included in the invite share message; unset = the
# "install from the link I sent you" fallback copy (no store URL is hardcoded).
EXPO_PUBLIC_APP_INSTALL_URL=

# ── Settings links: privacy / terms / support (src/lib/appLinks.ts) ──────────
# Optional overrides for the Settings screen's Privacy Policy, Terms of Use and
# support-contact rows. Unset/blank falls back to the documented placeholders
# (https://lullaby.app/privacy, https://lullaby.app/terms, support@lullaby.app).
# Point these at the real hosted pages / mailbox before an App Store submission.
EXPO_PUBLIC_PRIVACY_POLICY_URL=
EXPO_PUBLIC_TERMS_URL=
EXPO_PUBLIC_SUPPORT_EMAIL=
