# ─────────────────────────────────────────────────────────────────────────────
# Lullaby — example environment (safe beta defaults)
#
# Copy to .env for local development. Every EXPO_PUBLIC_* value is inlined into
# the JS bundle at build time and is therefore PUBLIC — never put a secret in
# an EXPO_PUBLIC_ variable. Release/beta env truth lives in docs/release-env.md.
#
# SAFE-BY-DEFAULT RULE: with this file copied verbatim, a build ships with
# Pro OFF, preview OFF, dev entitlement OFF, and normal onboarding.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (client-side; the PUBLIC anon key only — NEVER service_role) ────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── Google OAuth (web client id used for the PKCE sign-in flow) ──────────────
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ── Onboarding QA ─────────────────────────────────────────────────────────────
# Dev-only intro replay (inert in release builds: gated on __DEV__).
# MUST stay false for normal QA and for every beta/release build. On a dev
# build, true replays onboarding for no-session users and re-creates the local
# guest baby — use only on disposable installs for targeted onboarding QA.
EXPO_PUBLIC_FORCE_ONBOARDING=false

# ── Pro / RevenueCat ──────────────────────────────────────────────────────────
# Beta posture: Pro is OFF unless a build EXPLICITLY enables it AND provides
# real RevenueCat keys. "Enabled" with empty keys is an UNCONFIGURED state
# (the paywall renders a calm "not configured" notice) and is NOT beta-ready —
# see docs/release-env.md before flipping anything here.

# Real Pro (RevenueCat paywall + live gates). "1"/"true" to enable; off by default.
EXPO_PUBLIC_PRO_ENABLED=0
# Fake-door preview (interest analytics only, no payment). Off by default.
# Real Pro supersedes preview — the two can never show at once.
EXPO_PUBLIC_PRO_PREVIEW_ENABLED=0
# Dev/QA-only entitlement override (isPro = true without a purchase). Gated on
# __DEV__, so a shipped build always ignores it. Keep 0 except during local
# Pro QA on a dev build.
EXPO_PUBLIC_PRO_DEV_ENTITLEMENT=0

# RevenueCat PUBLIC SDK keys. Empty = RevenueCat unconfigured (no crash; Pro
# surfaces degrade calmly). Real values belong only in build profiles that
# intentionally ship Pro. These are the public SDK keys, not secret API keys.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
# Must match the RevenueCat dashboard. Code defaults: pro / default.
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=pro
EXPO_PUBLIC_REVENUECAT_OFFERING_ID=default

# ── Misc ──────────────────────────────────────────────────────────────────────
# Theme reveal animation duration override in ms. Empty = built-in default.
EXPO_PUBLIC_THEME_REVEAL_DURATION_MS=
# Install link used in the caregiver invite share message. Empty = omitted.
EXPO_PUBLIC_APP_INSTALL_URL=

# ── Server-side variables that must NEVER appear in this file ─────────────────
# REASSURE_NIGHT_READ_ENABLED is a Supabase edge-function secret (the server
# kill switch for the AI night-read), not an Expo env var. ANTHROPIC_API_KEY,
# REASSURE_MODEL, and SUPABASE_SERVICE_ROLE_KEY are server secrets; putting any
# of them in an EXPO_PUBLIC_ variable would ship them inside the app bundle.
