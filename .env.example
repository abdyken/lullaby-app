# Lullaby — local development flags
#
# These EXPO_PUBLIC_ values are safe to expose. Expo inlines them into the
# client bundle, so do not put secrets here. Copy this file to `.env` for local
# development.

EXPO_PUBLIC_LOGGING_V2=true
EXPO_PUBLIC_THEME_REVEAL_DURATION_MS=600

# Lullaby — Supabase sync (OPTIONAL)
#
# Lullaby runs as a complete LOCAL demo with NO backend. Leave these unset and
# the app stays in local-only mode (AsyncStorage), exactly as before.
#
# Set BOTH to enable the Supabase foundation. They are public values (the URL
# and the anon/publishable key only — never a service-role secret). Row Level
# Security in supabase/migrations is what actually protects caregiver data.
#
# The EXPO_PUBLIC_ prefix is required so Expo inlines them into the client
# bundle. Fill in these project values only when you want Supabase sync.
#
# With both set, the app shows an email + password sign-in, then a one-time baby
# setup, then enters real sync mode. Enable the Email auth provider in Supabase
# (and, for the smoothest first run, turn OFF "Confirm email"). See
# supabase/README.md for the full setup + first-run flow.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
