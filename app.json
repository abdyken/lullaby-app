{
  "expo": {
    "name": "Lullaby",
    "slug": "lullaby",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lullaby",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.lullaby.app",
      "supportsTablet": false,
      "usesAppleSignIn": true
    },
    "android": {
      "icon": "./assets/images/icon.png",
      "package": "com.lullaby.app",
      "adaptiveIcon": {
        "backgroundColor": "#E8D9FF",
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Lullaby uses the microphone so you can ask a question hands-free.",
          "speechRecognitionPermission": "Lullaby uses speech recognition to hear your question and route it to a safe answer.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E8D9FF",
          "image": "./assets/images/lullaby-logo-mark.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#E8D9FF",
            "image": "./assets/images/lullaby-logo-mark.png"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
